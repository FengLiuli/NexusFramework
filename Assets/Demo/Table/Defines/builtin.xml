<module name="">
    <bean name="vector2" valueType="1" sep=",">
        <var name="x" type="float"/>
        <var name="y" type="float"/>
    </bean>
    <bean name="vector3" valueType="1" sep=",">
        <var name="x" type="float"/>
        <var name="y" type="float"/>
        <var name="z" type="float"/>
    </bean>
    <bean name="vector4" valueType="1" sep=",">
        <var name="x" type="float"/>
        <var name="y" type="float"/>
        <var name="z" type="float"/>
        <var name="w" type="float"/>
    </bean>
    
    <bean name="AttributeInSet" valueType="1" sep=",">
        <var name="ID" type="int"/>
        <var name="InitValue" type="float"/>
        <var name="MinValue" type="float"/>
        <var name="MaxValue" type="float"/>
        <var name="UseMinValue" type="bool"/>
        <var name="UseMaxValue" type="bool"/>
    </bean>
    
    <bean name="GrantedAbility" valueType="1" sep=";">
        <var name="ID" type="int"/>
        <var name="Level" type="int"/>
        <var name="ActivationPolicy" type="int"/>
        <var name="DeactivationPolicy" type="int"/>
        <var name="RemovePolicy" type="int"/>
    </bean>

    <bean name="Modifier" valueType="1" sep=";">
        <var name="AttrSet" type="int"/>
        <var name="Attribute" type="int"/>
        <var name="Magnitude" type="float"/>
        <var name="Operation" type="int"/>
        <var name="Mmc" type="int"/>
    </bean>

    <bean name="Duration" valueType="1">
        <var name="TimeUnit" type="int"/>
        <var name="Time" type="int"/>
        <var name="ResetStartTimeWhenActivated" type="bool"/>
    </bean>

    <bean name="Period" valueType="1">
        <var name="Time" type="int"/>
        <var name="Effects" type="(array#sep=;),int"/>
        <var name="FirstTrigger" type="bool"/>
    </bean>

    <bean name="Stacking" valueType="1">
        <var name="StackingType" type="int"/>
        <var name="StackCode" type="int"/>
        <var name="LimitCount" type="int"/>
        <var name="DurationRefreshPolicy" type="int"/>
        <var name="PeriodResetPolicy" type="int"/>
        <var name="ExpirationPolicy" type="int"/>
        <var name="DenyOverflowApplication" type="bool"/>
        <var name="ClearStackOnOverflow" type="bool"/>
        <var name="OverflowEffects" type="(array#sep=;),int"/>
    </bean>

    <bean name="TaskClip" valueType="1" sep=",">
        <var name="StartTime" type="int"/>
        <var name="EndTime" type="int"/>
        <var name="Name" type="string"/>
        <var name="Task" type="AbilityTaskBase"/>
    </bean>
    
    <bean name="Track" valueType="1" sep=",">
        <var name="Name" type="string"/>
        <var name="TaskClips" type="array,TaskClip"/>
    </bean>

    <bean name="TagRequirementData" valueType="1" sep=";">
        <var name="All" type="(list#sep=,), int"/>
        <var name="Any" type="(list#sep=,), int"/>
        <var name="None" type="(list#sep=,), int"/>
    </bean>
</module>